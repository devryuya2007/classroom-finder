{
  "manifest_version": 3,
  "name": "Classroom-Finder",
  "version": "1.0.0",
  "description": "Google Classroom に高速横断検索を追加",
  "icons": {
    "16": "assets/icon/icon-16.png",
    "32": "assets/icon/icon-32.png",
    "48": "assets/icon/icon-48.png",
    "128": "assets/icon/icon-128.png"
  },
  "key": "",
  "permissions": ["storage", "scripting", "identity"],
  "host_permissions": ["https://classroom.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://classroom.google.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/gcx-topbar.css",
        "src/libs/icon.svg/検索用の虫眼鏡アイコン素材.svg",
        "src/libs/icon.svg/リロードのフリーアイコン.svg",
        "src/libs/fuse.esm.js"
      ],
      "matches": ["https://classroom.google.com/*"]
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "oauth2": {
    "client_id": "742269214393-qqmtj4pgku79831q0pi9s0vh236tc7cl.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/classroom.courses.readonly",
      "https://www.googleapis.com/auth/classroom.announcements.readonly"
    ]
  }
}
