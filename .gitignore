# Keep the samples folder in the repo but do not track its contents
/samples/*
!/samples/.gitkeep

# Node / tooling
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
out/
coverage/
*.log

# Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Env/secrets
.env
.env.local
.env.*.local
config/api-credentials.json
\n+# Local API config (do not track)
config/.env/API.json
